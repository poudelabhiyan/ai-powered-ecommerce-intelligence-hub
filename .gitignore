# Python cache files
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Virtual environment
venv/
.venv/
env/

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# Environment variables
.env

# Data files - keep large/raw data out of GitHub
data/raw/*
data/interim/*
data/processed/*

# Keep folder structure
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep

# Output files
outputs/figures/*
outputs/tables/*
outputs/reports/*

# Keep output folders
!outputs/figures/.gitkeep
!outputs/tables/.gitkeep
!outputs/reports/.gitkeep

# Power BI files
*.pbix
*.pbit

# Excel files
*.xlsx
*.xls
*.csv

# OS files
.DS_Store
Thumbs.db

# VS Code settings
.vscode/